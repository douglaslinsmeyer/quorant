  "typography": {
    "fontFamily": {
      "heading": "Manrope",
      "body":    "Inter",
      "mono":    "JetBrains Mono"
    },
    "scale": {
      "display": {
        "size":       48,
        "weight":     800,
        "lineHeight": 1.1,
        "font":       "heading"
      },
      "h1": {
        "size":       36,
        "weight":     700,
        "lineHeight": 1.2,
        "font":       "heading"
      },
      "h2": {
        "size":       28,
        "weight":     700,
        "lineHeight": 1.25,
        "font":       "heading"
      },
      "h3": {
        "size":       22,
        "weight":     600,
        "lineHeight": 1.3,
