# ─── Server ────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ─── Database ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=quorant
DB_PASSWORD=quorant
DB_NAME=quorant_dev
DB_SSLMODE=disable
DB_MAX_CONNS=25

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── NATS ───────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── S3 / MinIO ─────────────────────────────────────────────────────────────
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=quorant-documents
S3_USE_SSL=false

# ─── Zitadel ────────────────────────────────────────────────────────────────
ZITADEL_DOMAIN=localhost:8085
ZITADEL_ISSUER=http://localhost:8085

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
